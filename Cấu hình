-- [[ 1. THIẾT LẬP HỆ THỐNG & CẤU HÌNH ]] --
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local Global_Green = Color3.fromRGB(0, 255, 127)
local Global_Red = Color3.fromRGB(255, 45, 45)

_G.Config = {
    Aimbot = false, SilentAim = false, FOVSize = 120, ShowFOV = false,
    Hitbox = false, HitboxSize = 25,
    ESP_Line = false, ESP_Box = false, ESP_HP = false,
    NoGun = false, AntiStun = false, Smoothness = 0.1
}

-- [[ 2. HỆ THỐNG VẼ (CHỐNG LAG / CHỐNG MẠNG NHỆN) ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5; FOVCircle.Color = Global_Green; FOVCircle.Filled = false

local ESP_Cache = {}

local function CreateESP(plr)
    if ESP_Cache[plr] then return end
    ESP_Cache[plr] = {
        Line = Drawing.new("Line"),
        Box = Drawing.new("Square"),
        Health = Drawing.new("Text")
    }
    local data = ESP_Cache[plr]
    data.Line.Thickness = 1.5; data.Box.Thickness = 1.5
end

local function RemoveESP(plr)
    if ESP_Cache[plr] then
        ESP_Cache[plr].Line:Remove()
        ESP_Cache[plr].Box:Remove()
        ESP_Cache[plr].Health:Remove()
        ESP_Cache[plr] = nil
    end
end

-- [[ 3. LOGIC XỬ LÝ (SILENT AIM & AIMBOT) ]] --
local function GetClosestTarget()
    local target = nil; local dist = _G.Config.FOVSize
    local mousePos = UserInputService:GetMouseLocation()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hum = v.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local pos, vis = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if mag < dist then target = v; dist = mag end
                end
            end
        end
    end
    return target
end

-- Bẻ hướng chiêu (Silent Aim)
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    if _G.Config.SilentAim and method == "FireServer" then
        local target = GetClosestTarget()
        if target and target.Character then
            for i, v in pairs(args) do
                if typeof(v) == "Vector3" then args[i] = target.Character.HumanoidRootPart.Position
                elseif typeof(v) == "CFrame" then args[i] = target.Character.HumanoidRootPart.CFrame end
            end
        end
    end
    return oldNamecall(self, unpack(args))
end)

-- Vòng lặp Render chính
RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = _G.Config.ShowFOV
    FOVCircle.Radius = _G.Config.FOVSize
    FOVCircle.Position = UserInputService:GetMouseLocation()

    for plr, data in pairs(ESP_Cache) do
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")

        if hrp and hum and hum.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local sizeX, sizeY = 2500 / pos.Z, 3500 / pos.Z
                -- Cập nhật Line
                data.Line.Visible = _G.Config.ESP_Line
                data.Line.From = Vector2.new(Camera.ViewportSize.X/2, 0)
                data.Line.To = Vector2.new(pos.X, pos.Y - sizeY/2)
                data.Line.Color = Global_Green
                -- Cập nhật Box
                data.Box.Visible = _G.Config.ESP_Box
                data.Box.Size = Vector2.new(sizeX, sizeY)
                data.Box.Position = Vector2.new(pos.X - sizeX/2, pos.Y - sizeY/2)
                data.Box.Color = Global_Green
                -- Cập nhật HP
                data.Health.Visible = _G.Config.ESP_HP
                data.Health.Text = "HP: "..math.floor(hum.Health)
                data.Health.Position = Vector2.new(pos.X, pos.Y + sizeY/2 + 5)
                data.Health.Color = Global_Green; data.Health.Center = true; data.Health.Outline = true
            else
                data.Line.Visible = false; data.Box.Visible = false; data.Health.Visible = false
            end
        else
            data.Line.Visible = false; data.Box.Visible = false; data.Health.Visible = false
        end
    end

    -- Hitbox & No Gun
    if _G.Config.Hitbox then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                v.Character.HumanoidRootPart.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                v.Character.HumanoidRootPart.Transparency = 0.8; v.Character.HumanoidRootPart.CanCollide = false
            end
        end
    end

    if _G.Config.NoGun then
        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool and (tool:FindFirstChild("Gun") or tool.ToolTip == "Gun") then tool.Parent = LocalPlayer.Backpack end
    end
end)

-- [[ 4. GIAO DIỆN MENU ]] --
