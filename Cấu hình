    local Main = Instance.new("Frame", Screen); Main.Size = UDim2.new(0, 260, 0, 480); Main.Position = UDim2.new(0.5, -130, 0.5, -240); Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20); Main.Draggable = true; Main.Active = true; Instance.new("UICorner", Main)
    
    local Head = Instance.new("Frame", Main); Head.Size = UDim2.new(1, 0, 0, 40); Head.BackgroundColor3 = Global_Red; Instance.new("UICorner", Head)
    local Title = Instance.new("TextLabel", Head); Title.Size = UDim2.new(1,0,1,0); Title.Text = "BLOX FRUIT MAX (NO KEY)"; Title.TextColor3 = Color3.new(1,1,1); Title.Font = "GothamBold"; Title.BackgroundTransparency = 1

    local function CreateBtn(name, configKey, y)
        local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0, 220, 0, 32); b.Position = UDim2.new(0.5, -110, 0, y); b.Text = name; b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1,1,1); b.Font = "GothamBold"; b.TextSize = 10; Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(function() 
            _G.Config[configKey] = not _G.Config[configKey]
            b.BackgroundColor3 = _G.Config[configKey] and Global_Green or Color3.fromRGB(35, 35, 35)
            b.TextColor3 = _G.Config[configKey] and Color3.new(0,0,0) or Color3.new(1,1,1)
        end)
    end

    CreateBtn("SILENT AIM (BẺ CHIÊU)", "SilentAim", 60)
    CreateBtn("HIỆN VÒNG TRÒN FOV", "ShowFOV", 100)
    CreateBtn("SIÊU HITBOX", "Hitbox", 140)
    CreateBtn("ESP LINE", "ESP_Line", 180)
    CreateBtn("ESP BOX", "ESP_Box", 220)
    CreateBtn("ESP HEALTH", "ESP_HP", 260)
    CreateBtn("KHÓA SÚNG (NO GUN)", "NoGun", 300)
    CreateBtn("CHỐNG CHOÁNG (ANTI-STUN)", "AntiStun", 340)

    local OpenBtn = Instance.new("TextButton", Screen); OpenBtn.Size = UDim2.new(0, 40, 0, 40); OpenBtn.Position = UDim2.new(0, 10, 0.5, 0); OpenBtn.Text = "F"; OpenBtn.BackgroundColor3 = Global_Red; OpenBtn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", OpenBtn).CornerRadius = UDim.new(1,0)
    OpenBtn.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
end

-- Khởi tạo
Players.PlayerRemoving:Connect(RemoveESP)
for _, v in pairs(Players:GetPlayers()) do CreateESP(v) end
Players.PlayerAdded:Connect(CreateESP)
LaunchMenu()
