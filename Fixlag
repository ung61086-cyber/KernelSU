-- [5] TÍNH NĂNG CLONE TOOL ĐỘC LẬP
----------------------------------------------------------------
local function attemptToolClone()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local activeTool = character:FindFirstChildOfClass("Tool")
    
    if not activeTool then
        showNotification("Không cầm Tool trên tay!", Color3.fromRGB(255, 80, 80))
        return
    end
    
    local cloneSuccess, clonedTool = pcall(function()
        return activeTool:Clone()
    end)
    
    if cloneSuccess and clonedTool then
        local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
        if backpack then
            clonedTool.Parent = backpack
            showNotification("Clone thành công!", Color3.fromRGB(80, 255, 80))
        else
            showNotification("Lỗi: Không tìm thấy Backpack!", Color3.fromRGB(255, 80, 80))
        end
    else
        showNotification("Clone thất bại!", Color3.fromRGB(255, 80, 80))
    end
end

----------------------------------------------------------------
-- [6] TỐI ƯU HÓA HOẠT ẢNH & ĐỒ HỌA LŨY TIẾN (BOOST FPS CẤP SỐ NHÂN)
----------------------------------------------------------------
local function cleanObject(obj)
    if obj:IsA("Decal") or obj:IsA("Texture") then
        obj:Destroy()
    elseif obj:IsA("SpecialMesh") then
        obj.TextureId = ""
    elseif obj:IsA("MeshPart") then
        obj.TextureID = ""
        if boostLevel >= 2 then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
        end
    elseif obj:IsA("BasePart") then
        obj.Material = Enum.Material.SmoothPlastic
        obj.Reflectance = 0
        obj.CastShadow = false
    elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
        obj.Enabled = false
        if boostLevel >= 3 then
            obj:Destroy()
        end
    elseif obj:IsA("Light") and boostLevel >= 2 then
        obj.Enabled = false
    end
end

local function applyExponentialBoost()
    boostLevel = boostLevel + 1
    
    -- Thực hiện quét toàn bộ Workspace để dọn dẹp
    for _, descendant in ipairs(Workspace:GetDescendants()) do
        cleanObject(descendant)
    end

    -- Khởi tạo lắng nghe nếu ở level 1
    if boostLevel == 1 then
        Workspace.DescendantAdded:Connect(function(descendant)
            cleanObject(descendant)
        end)
    end
    
    -- Tăng cường tối ưu luồng game ở cấp độ cao
    if boostLevel >= 2 then
        sethiddenproperty = sethiddenproperty or function(...) end
        pcall(function()
            sethiddenproperty(workspace, "StreamingEnabled", true)
            sethiddenproperty(Lighting, "Technology", Enum.Technology.Compatibility)
        end)
    end
end

-- Tối ưu hóa cài đặt đồ họa tổng quan của Roblox ngay khi vừa mở game
local function initGlobalOptimization()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.Brightness = 1
    
    for _, service in ipairs({game:GetService("MaterialService"), Lighting}) do
        for _, child in ipairs(service:GetChildren()) do
            if child:IsA("PostEffect") or child:IsA("Atmosphere") or child:IsA("Clouds") then
                child.Enabled = false
            end
        end
    end
end
task.spawn(initGlobalOptimization)

