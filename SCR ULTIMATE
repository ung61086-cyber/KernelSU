-- [[ 1. KHỞI TẠO HỆ THỐNG AN TOÀN ]] --
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Cấu hình hệ thống (Mặc định tắt hết để an toàn)
_G.Config = {
    Aimbot = false, ShowFOV = false, FOVSize = 120, Smoothness = 0.1, AimPart = "Head",
    ESP_Box = false, ESP_HP = false, HitboxHead = false, HitboxBody = false, HitboxSize = 25,
    AutoClick = false, SpeedHack = false, SpeedValue = 50, JumpHack = false, JumpValue = 100,
    InfJump = false
}

local Global_Red = Color3.fromRGB(255, 40, 40)
local Global_Green = Color3.fromRGB(0, 255, 127)
local MasterKey = "tudeptrai2013"

-- [[ 2. HỆ THỐNG VẬN ĐỘNG & AUTO (RESETS TỨ THÌ) ]] --
RunService.Heartbeat:Connect(function()
    local Char = LocalPlayer.Character
    local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
    if Hum then
        -- Tốc độ & Nhảy
        Hum.WalkSpeed = _G.Config.SpeedHack and _G.Config.SpeedValue or 16
        if _G.Config.JumpHack then
            Hum.JumpPower = _G.Config.JumpValue
            Hum.UseJumpPower = true
        else
            Hum.JumpPower = 50
        end
    end
    -- Clicker
    if _G.Config.AutoClick then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton1(Vector2.new(0,0))
    end
end)

-- Bay (Infinite Jump)
UserInputService.JumpRequest:Connect(function()
    if _G.Config.InfJump then
        local Hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Hum then Hum:ChangeState("Jumping") end
    end
end)

-- [[ 3. LOGIC AIMBOT ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5; FOVCircle.Color = Global_Green; FOVCircle.Filled = false

local function GetClosest()
    local target, shortestDist = nil, _G.Config.FOVSize
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(_G.Config.AimPart) then
            local Hum = v.Character:FindFirstChildOfClass("Humanoid")
            if Hum and Hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(v.Character[_G.Config.AimPart].Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < shortestDist then target = v; shortestDist = dist end
                end
            end
        end
    end
    return target
end

-- [[ 4. QUẢN LÝ ESP & HITBOX (RESET 100%) ]] --
local function ManagePlayer(plr)
    local Lines = {}; for i=1,8 do Lines[i] = Drawing.new("Line"); Lines[i].Thickness = 1.5; Lines[i].Color = Global_Green end
    local HB_Back = Drawing.new("Line"); HB_Back.Thickness = 4; HB_Back.Color = Color3.new(0,0,0)
    local HB_Main = Drawing.new("Line"); HB_Main.Thickness = 2
    local HT = Drawing.new("Text"); HT.Size = 14; HT.Outline = true; HT.Center = true; HT.Color = Color3.new(1,1,1)

    RunService.RenderStepped:Connect(function()
        if not plr or not plr.Parent then 
            for _, l in pairs(Lines) do l:Remove() end
            HB_Back:Remove(); HB_Main:Remove(); HT:Remove(); return 
        end

        FOVCircle.Visible = _G.Config.ShowFOV; FOVCircle.Radius = _G.Config.FOVSize; FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        
        if _G.Config.Aimbot then
            local t = GetClosest()
            if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character[_G.Config.AimPart].Position), _G.Config.Smoothness) end
        end

        local Char = plr.Character
        if Char then
            local Root = Char:FindFirstChild("HumanoidRootPart")
            local Head = Char:FindFirstChild("Head")
            local Hum = Char:FindFirstChildOfClass("Humanoid")

            if Root and Head and Hum then
                -- HITBOX LOGIC (Reset khi tắt)
                if _G.Config.HitboxHead and Hum.Health > 0 then
                    Head.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Head.Transparency = 0.7; Head.CanCollide = false
                else
                    Head.Size = Vector3.new(1.2, 1.2, 1.2); Head.Transparency = 0; Head.CanCollide = true
                end

                if _G.Config.HitboxBody and Hum.Health > 0 then
                    Root.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Root.Transparency = 0.7; Root.CanCollide = false
                else
                    Root.Size = Vector3.new(2, 2, 1); Root.Transparency = 1; Root.CanCollide = true
                end

                -- ESP DRAWING
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                if OnScreen and Hum.Health > 0 and plr ~= LocalPlayer then
                    local SX, SY = 2200/Pos.Z, 3200/Pos.Z
                    local X, Y, F = Pos.X, Pos.Y, (2200/Pos.Z)*0.25
                    for i=1,8 do Lines[i].Visible = _G.Config.ESP_Box end
                    if _G.Config.ESP_Box then
                        Lines[1].From = Vector2.new(X-SX/2, Y-SY/2); Lines[1].To = Vector2.new(X-SX/2+F, Y-SY/2)
                        Lines[2].From = Vector2.new(X-SX/2, Y-SY/2); Lines[2].To = Vector2.new(X-SX/2, Y-SY/2+F)
                        Lines[3].From = Vector2.new(X+SX/2, Y-SY/2); Lines[3].To = Vector2.new(X+SX/2-F, Y-SY/2)
                        Lines[4].From = Vector2.new(X+SX/2, Y-SY/2); Lines[4].To = Vector2.new(X+SX/2, Y-SY/2+F)
                        Lines[5].From = Vector2.new(X-SX/2, Y+SY/2); Lines[5].To = Vector2.new(X-SX/2+F, Y+SY/2)
                        Lines[6].From = Vector2.new(X-SX/2, Y+SY/2); Lines[6].To = Vector2.new(X-SX/2, Y+SY/2-F)
                        Lines[7].From = Vector2.new(X+SX/2, Y+SY/2); Lines[7].To = Vector2.new(X+SX/2-F, Y+SY/2)
                        Lines[8].From = Vector2.new(X+SX/2, Y+SY/2); Lines[8].To = Vector2.new(X+SX/2, Y+SY/2-F)
                    end
                    if _G.Config.ESP_HP then
                        local BX = X-SX/2-6; local HH = (Hum.Health/Hum.MaxHealth)*SY
                        HB_Back.Visible = true; HB_Back.From = Vector2.new(BX, Y+SY/2); HB_Back.To = Vector2.new(BX, Y-SY/2)
                        HB_Main.Visible = true; HB_Main.From = Vector2.new(BX, Y+SY/2); HB_Main.To = Vector2.new(BX, (Y+SY/2)-HH); HB_Main.Color = Global_Green:Lerp(Global_Red, 1-(Hum.Health/Hum.MaxHealth))
                        HT.Visible = true; HT.Text = math.floor(Hum.Health); HT.Position = Vector2.new(BX-15, (Y+SY/2)-HH-7)
                    else HB_Back.Visible=false; HB_Main.Visible=false; HT.Visible=false end
                else 
                    for i=1,8 do Lines[i].Visible = false end; HB_Back.Visible = false; HB_Main.Visible = false; HT.Visible = false 
                end
            end
        end
    end)
end

