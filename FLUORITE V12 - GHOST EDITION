    Aimbot = false, ShowFOV = false, FOVSize = 120, Smoothness = 0.1, AimPart = "Head",
    ESP_Box = false, ESP_HP = false, 
    HitboxHead = false, HitboxBody = false, HitboxSize = 25, 
    AutoClick = false, SpeedHack = false, SpeedValue = 50, 
    JumpHack = false, JumpValue = 100, InfJump = false
}

