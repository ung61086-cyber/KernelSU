local Global_Green = Color3.fromRGB(0, 255, 150)

-- [[ 2. LOGIC VẬN ĐỘNG & AUTO ]] --
RunService.Heartbeat:Connect(function()
    local Hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if Hum then
        -- Chạy nhanh & Nhảy cao
        Hum.WalkSpeed = _G.Config.SpeedHack and _G.Config.SpeedValue or 16
        if _G.Config.JumpHack then
            Hum.JumpPower = _G.Config.JumpValue
            Hum.UseJumpPower = true
        else
            Hum.JumpPower = 50
        end
    end
    -- Auto Click
    if _G.Config.AutoClick then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton1(Vector2.new(0,0))
    end
end)

-- Bay (Infinite Jump)
UserInputService.JumpRequest:Connect(function()
    if _G.Config.InfJump then
        local Hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if Hum then Hum:ChangeState("Jumping") end
    end
end)

-- [[ 3. LOGIC HITBOX TÀNG HÌNH (FIX LỖI VIDEO) ]] --
local function ProcessHitbox(v)
    if v ~= LocalPlayer and v.Character then
        local Root = v.Character:FindFirstChild("HumanoidRootPart")
        local Head = v.Character:FindFirstChild("Head")
        local Hum = v.Character:FindFirstChildOfClass("Humanoid")

        if Hum and Hum.Health > 0 then
            -- Fix lỗi khối trắng bằng cách chỉnh Transparency = 1 (Tàng hình)
            if _G.Config.HitboxBody and Root then
                Root.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                Root.Transparency = 1 -- 100% tàng hình
                Root.CanCollide = false -- Không gây văng
            elseif Root then
                Root.Size = Vector3.new(2, 2, 1)
                Root.Transparency = 1
                Root.CanCollide = true
            end

            if _G.Config.HitboxHead and Head then
                Head.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                Head.Transparency = 0.5 -- Đầu cho mờ mờ để dễ ngắm
                Head.CanCollide = false
            elseif Head then
                Head.Size = Vector3.new(1.2, 1.2, 1.2)
                Head.Transparency = 0
                Head.CanCollide = true
            end
        end
    end
end

RunService.RenderStepped:Connect(function()
    for _, v in pairs(Players:GetPlayers()) do
        task.spawn(function() ProcessHitbox(v) end)
    end
end)

