-- 5. VÒNG LẶP HỆ THỐNG (AIMBOT & ESP)
RunService.RenderStepped:Connect(function()
    local Center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Position = Center
    FOVCircle.Radius = _G.Radius

    if _G.Aimbot then
        local target = nil
        local dist = _G.Radius
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= Player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local pos, screen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                if screen then
                    local magnitude = (Vector2.new(pos.X, pos.Y) - Center).Magnitude
                    if magnitude < dist then
                        target = v.Character.HumanoidRootPart
                        dist = magnitude
                    end
                end
            end
        end
        if target then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
        end
    end
end)
