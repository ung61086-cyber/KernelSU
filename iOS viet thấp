-- HÀM TẠO NÚT CHỨC NĂNG (CHỮ ĐỔI XANH LÁ)
local function AddFunc(name, isSlider, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(1, 0, 0, 45)
    btn.BackgroundColor3 = isSlider and Color3.fromRGB(0, 0, 255) or Color3.fromRGB(60, 60, 60)
    btn.Text = name
    btn.Font = Enum.Font.GothamBold
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(30, 30, 30)

    if not isSlider then
        local active = false
        btn.MouseButton1Click:Connect(function()
            active = not active
            btn.TextColor3 = active and Color3.fromRGB(0, 255, 0) or Color3.new(1, 1, 1)
            callback(active)
        end)
    end
end

-- THỨ TỰ CÁC DÒNG Y HỆT VIDEO
