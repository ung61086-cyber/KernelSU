-- [[ 4. HỆ THỐNG CHIẾN ĐẤU & ESP ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5; FOVCircle.Color = Global_Red; FOVCircle.Filled = false

local function GetClosest()
    local t, dist = nil, _G.Config.FOVSize
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(_G.Config.AimPart) then
            local Hum = v.Character:FindFirstChild("Humanoid")
            if Hum and Hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(v.Character[_G.Config.AimPart].Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if mag < dist then t = v; dist = mag end
                end
            end
        end
    end
    return t
end

local function CreateESP(plr)
    local Lines = {}
    for i=1,8 do Lines[i] = Drawing.new("Line"); Lines[i].Thickness = 1.5; Lines[i].Color = Global_Red end
    local MainLine = Drawing.new("Line"); MainLine.Color = Global_Red
    local HB_Back = Drawing.new("Line"); HB_Back.Thickness = 4; HB_Back.Color = Color3.new(0,0,0)
    local HB_Main = Drawing.new("Line"); HB_Main.Thickness = 2
    local HT = Drawing.new("Text"); HT.Size = 14; HT.Outline = true; HT.Center = true; HT.Color = Color3.new(1,1,1)

    RunService.RenderStepped:Connect(function()
        if not plr.Parent then 
            for _, l in pairs(Lines) do l:Remove() end
            MainLine:Remove(); HB_Back:Remove(); HB_Main:Remove(); HT:Remove(); return 
        end
        FOVCircle.Visible = _G.Config.ShowFOV; FOVCircle.Radius = _G.Config.FOVSize; FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        
        if _G.Config.Aimbot then
            local t = GetClosest()
            if t then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, t.Character[_G.Config.AimPart].Position), _G.Config.Smoothness) end
        end

        if plr.Character and plr ~= LocalPlayer then
            local Root = plr.Character:FindFirstChild("HumanoidRootPart")
            local Head = plr.Character:FindFirstChild("Head")
            local Hum = plr.Character:FindFirstChild("Humanoid")

            if Root and Head and Hum and Hum.Health > 0 then
                -- HITBOX LOGIC & GHOST
                if _G.Config.HitboxHead then
                    Head.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Head.Transparency = 0.7; Head.CanCollide = false
                else Head.Size = Vector3.new(1.2, 1.2, 1.2); Head.Transparency = 0 end

                if _G.Config.HitboxBody then
                    Root.Size = Vector3.new(_G.Config.HitboxSize, _G.Config.HitboxSize, _G.Config.HitboxSize)
                    Root.Transparency = 0.8; Root.CanCollide = false
                else Root.Size = Vector3.new(2, 2, 1); Root.Transparency = 1 end

                if _G.Config.HitboxHead or _G.Config.HitboxBody then
                    for _, p in pairs(plr.Character:GetChildren()) do if p:IsA("BasePart") then p.CanCollide = false end end
                end

                -- ESP DRAWING
                local Pos, OnScreen = Camera:WorldToViewportPoint(Root.Position)
                if OnScreen then
                    local SX, SY = 2200/Pos.Z, 3200/Pos.Z
                    local X, Y, F = Pos.X, Pos.Y, (2200/Pos.Z)*0.25
                    for _, l in pairs(Lines) do l.Visible = _G.Config.ESP_Box end
                    if _G.Config.ESP_Box then
                        Lines[1].From = Vector2.new(X-SX/2, Y-SY/2); Lines[1].To = Vector2.new(X-SX/2+F, Y-SY/2)
                        Lines[2].From = Vector2.new(X-SX/2, Y-SY/2); Lines[2].To = Vector2.new(X-SX/2, Y-SY/2+F)
                        Lines[3].From = Vector2.new(X+SX/2, Y-SY/2); Lines[3].To = Vector2.new(X+SX/2-F, Y-SY/2)
                        Lines[4].From = Vector2.new(X+SX/2, Y-SY/2); Lines[4].To = Vector2.new(X+SX/2, Y-SY/2+F)
                        Lines[5].From = Vector2.new(X-SX/2, Y+SY/2); Lines[5].To = Vector2.new(X-SX/2+F, Y+SY/2)
                        Lines[6].From = Vector2.new(X-SX/2, Y+SY/2); Lines[6].To = Vector2.new(X-SX/2, Y+SY/2-F)
                        Lines[7].From = Vector2.new(X+SX/2, Y+SY/2); Lines[7].To = Vector2.new(X+SX/2-F, Y+SY/2)
                        Lines[8].From = Vector2.new(X+SX/2, Y+SY/2); Lines[8].To = Vector2.new(X+SX/2, Y+SY/2-F)
                    end
                    if _G.Config.ESP_HP then
                        local BX = X-SX/2-6; local HH = (Hum.Health/Hum.MaxHealth)*SY
                        HB_Back.Visible = true; HB_Back.From = Vector2.new(BX, Y+SY/2); HB_Back.To = Vector2.new(BX, Y-SY/2)
                        HB_Main.Visible = true; HB_Main.From = Vector2.new(BX, Y+SY/2); HB_Main.To = Vector2.new(BX, (Y+SY/2)-HH); HB_Main.Color = Global_Green:Lerp(Global_Red, 1-(Hum.Health/Hum.MaxHealth))
                        HT.Visible = true; HT.Text = math.floor(Hum.Health); HT.Position = Vector2.new(BX-15, (Y+SY/2)-HH-7)
                    else HB_Back.Visible=false; HB_Main.Visible=false; HT.Visible=false end
                    MainLine.Visible = _G.Config.ESP_Line; MainLine.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); MainLine.To = Vector2.new(X, Y+SY/2)
                else for _, l in pairs(Lines) do l.Visible = false end; MainLine.Visible = false; HB_Back.Visible = false; HB_Main.Visible = false; HT.Visible = false end
            end
        end
    end)
end

